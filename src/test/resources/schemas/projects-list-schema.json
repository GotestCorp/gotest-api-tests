{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProjectsList",
  "description": "Lista de projetos. Se a API envelopa em { data: [...] }, ajuste para usar 'object' com 'data' como property.",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "name"],
    "properties": {
      "id": { "type": "string" },
      "name": { "type": "string", "minLength": 1 },
      "description": { "type": ["string", "null"] },
      "createdAt": { "type": ["string", "null"] },
      "updatedAt": { "type": ["string", "null"] }
    },
    "additionalProperties": true
  }
}
