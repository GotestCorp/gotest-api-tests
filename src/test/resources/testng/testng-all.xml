<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Full Regression" verbose="1">

    <listeners>
        <listener class-name="br.com.gotest.apitests.listener.TestListener"/>
    </listeners>

    <test name="HealthCheck">
        <packages>
            <package name="br.com.gotest.apitests.healthcheck"/>
        </packages>
    </test>

    <test name="Contract">
        <packages>
            <package name="br.com.gotest.apitests.contract"/>
        </packages>
    </test>

    <test name="Functional">
        <packages>
            <package name="br.com.gotest.apitests.functional"/>
        </packages>
    </test>
</suite>
