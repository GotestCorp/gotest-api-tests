# =============================================================================
# Modelo de configuração da suite de testes.
#
# Copie este arquivo para config.properties e preencha os valores reais:
#   cp config.properties.example config.properties
#
# config.properties está no .gitignore — NÃO commite credenciais reais.
#
# Precedência (do mais forte ao mais fraco):
#   1) -Dchave=valor na linha de comando do Maven
#   2) Variável de ambiente (ex: BASEURL, AUTH_EMAIL, DEFAULT_PROJECT_ID)
#   3) config.properties
#
# No CI, prefira variáveis de ambiente / secrets em vez do arquivo.
# =============================================================================

# URL base da API (sem barra no final).
baseUrl=https://gotest.com.br/api/api

# --- Autenticação ---
# Os JWTs dessa API expiram em ~24h. Em vez de colar um token fixo que vence
# todo dia, prefira auth.email + auth.password: a suite loga sozinha em
# POST /auth/login na primeira chamada e cacheia o token em memória pelo
# resto da execução (ver AuthTokenProvider).
auth.email=SEU_EMAIL_AQUI
auth.password=SUA_SENHA_AQUI

# Alternativa: cole um token JWT já pronto (tem prioridade sobre email/senha
# acima quando preenchido). Útil pra debugar contra um token específico.
#auth.token=COLE_SEU_TOKEN_JWT_AQUI

# ID de um projeto válido pra rodar testes que dependem de um projeto existente.
default.project.id=SEU_PROJECT_ID_AQUI

# ID de uma suite válida pra rodar testes que dependem de uma suite existente.
default.suite.id=SEU_SUITE_ID_AQUI

# Timeouts em milissegundos
timeout.connection=10000
timeout.response=30000

# Habilita request/response logging em todas as chamadas (ruidoso em CI)
log.enabled=true
