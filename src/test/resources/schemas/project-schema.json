{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Project",
  "description": "Estrutura esperada de um Projeto. AJUSTE com base no response real da API.",
  "type": "object",
  "required": ["id", "name"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Identificador único, geralmente UUID"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": ["string", "null"]
    },
    "createdAt": {
      "type": ["string", "null"]
    },
    "updatedAt": {
      "type": ["string", "null"]
    },
    "ownerId": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": true
}
